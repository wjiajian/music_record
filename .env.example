# 你的网易云 UID（听歌排行需在客户端设为「公开」）。必填。
NETEASE_UID=

# 网易云登录 Cookie（只需 MUSIC_U 一项，无它则 playCount 全为 0 且会被限流）。必填。
NETEASE_COOKIE=

# 统计时区（默认 Asia/Shanghai）
# TZ_NAME=Asia/Shanghai

# 差分归属规则：prev=凌晨抓取归前一天；same=23:55 抓取归当天（默认 prev）
# ATTRIBUTION=prev

# 数据库路径（默认 data/music.db）
# DB_PATH=

# API 服务端口与绑定地址（默认 3000 / 127.0.0.1）
# API_PORT=3000
# API_HOST=127.0.0.1
# ⚠ 部署到服务器要对外访问时才改 0.0.0.0；但本服务无鉴权且 .env 含 cookie，
#   建议 API_HOST 保持 127.0.0.1，由 nginx 反代对外（后续部署再配）。

# ---- 进程内每日采集调度（替代 OS 定时任务；见 src/collector/scheduler.js）----
# 是否在 api 进程内挂定时采集（默认开）。设 0 = 纯只读 api、不采集。
# COLLECT_IN_API=1
# 每日采集触发的本地时刻 HH:mm（默认 04:00，配合 ATTRIBUTION=prev 凌晨抓归前一天）
# COLLECT_AT=04:00
# api 启动时若当天还没抓过快照则立即补抓一次（默认关；开=1，慎用：
#   白天抓会让 prev 归属日错乱，仅建议在服务器 systemd 常驻时按需开启）
# COLLECT_ON_START=0

# ---- 高频最近播放计数器 ----
# 是否在 api 进程内每分钟采集最近播放（默认开）。
# REALTIME_IN_API=1
# 轮询间隔毫秒；默认 60000，最低限制 15000，过短可能触发网易云限流。
# REALTIME_INTERVAL_MS=60000
# recent 接口抓取条数，默认/上限 300。
# REALTIME_LIMIT=300
